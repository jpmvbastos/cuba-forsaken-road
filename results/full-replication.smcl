{cmd:________________________________}

{cmd:allsynth is a user-written command made freely-available to the research community. Please cite the paper:}

{browse "https://justinwiltshire.com/s/allsynth_Wiltshire.pdf":Wiltshire, Justin C., 2022.  allsynth: (Stacked) Synthetic Control Bias-Correction Utilities for Stata. Working paper.}

{hline}

{com}. 
. //------------------------------------------------------------------------------
. // Clean and merge data
. //------------------------------------------------------------------------------
. 
. foreach var in gdppc23 adj_mad23 adj_transf23 {c -(}
{txt}  2{com}.     
.         // Load placeholder data
.     use "$path/results/gdp-results.dta", clear 
{txt}  3{com}.     keep country id year `var' `var'_synth `var'_pval
{txt}  4{com}.     
.         // Keep only Cuba and relevant years
.         keep if id==8
{txt}  5{com}.         
.         // Declare temp file to store cleaned data
.     tempfile to_merge 
{txt}  6{com}. 
.     foreach j in 1 3 4 5 6 7 9 10 11 13 15 16 17 20 21 {c -(}
{txt}  7{com}.                         
.                 preserve 
{txt}  8{com}.         
.                 // Load Data
.                 use "$path/results/jackknife-gdp/`var'-out`j'.dta", clear
{txt}  9{com}.                 keep if id==8
{txt} 10{com}.                 
.                 cap drop unique_W
{txt} 11{com}.                 rename _time year
{txt} 12{com}.                         
.                 // Compute p-values following Galliani and Quirstoff
.                 qui sum N 
{txt} 13{com}.                 scalar J = r(mean)
{txt} 14{com}.                 cap gen `var'_pval_out`j' = (rmspe_rank - 1) / (J - 1)
{txt} 15{com}.                 
.                 cap drop p 
{txt} 16{com}.                 cap drop _Y_treated
{txt} 17{com}.                 
.                 // Rename variables
.                 rename _Y_synthetic `var'_synth_out`j'
{txt} 18{com}.                 
.                 foreach v in gap rmspe N _Co_Number _W_Weight rmspe_rank {c -(}
{txt} 19{com}.                         cap rename `v' `var'_`v'_out`j'
{txt} 20{com}.                 {c )-}
{txt} 21{com}.                 
.                 // Save the cleaned data
.                 save `to_merge', replace
{txt} 22{com}.                 
.                 restore
{txt} 23{com}.                 
.                 // Merge to main dataset
.                 qui merge 1:1 id year using `to_merge'
{txt} 24{com}.                 drop _merge
{txt} 25{com}.                 {c )-}
{txt} 26{com}. 
.         save "$path/results/jackknife-gdp/`var'-jackknife-results.dta", replace
