{txt}(19 real changes made)

{com}. 
. *gen synth_year so we have uniform coding across paper -- YEAR 11 is EVENT YEAR
. gen synth_year = event_time + 11
{txt}
{com}. 
. *Fix country names to allow two events per country
. replace country = "Albania2" if country == "Albania" & year > 1986
{txt}(0 real changes made)

{com}. replace country = "Myanmar2" if country == "Myanmar" & year > 1984
{txt}(21 real changes made)

{com}. replace country = "Romania2" if country == "Romania" & year > 1975
{txt}(0 real changes made)

{com}. 
. drop c
{txt}
{com}. encode country, gen(c)
{txt}
{com}. 
. *Invert outcomes (higher value = more corruption control, consistent with other measures)
. replace v2x_pubcorr   = 1 - v2x_pubcorr
{txt}(399 real changes made)

{com}. replace v2x_corr      = 1 - v2x_corr
{txt}(399 real changes made)

{com}. replace v2xnp_regcorr = 1 - v2xnp_regcorr
{txt}(399 real changes made)

{com}. 
