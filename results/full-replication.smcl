{com}. 
. 
. //------------------------------------------------------------------------------
. // Calculate Standardized p-values 
. //------------------------------------------------------------------------------
. 
. foreach var in us_trade_th trade_th {c -(}
{txt}  2{com}.         
.         // Compute p-values following Galliani and Quirstoff
.         qui distinct country if sample_`var'==1
{txt}  3{com}.         scalar J = r(ndistinct)
{txt}  4{com}.         cap gen `var'_pval = (`var'_rmspe_rank - 1) / (J - 1)
{txt}  5{com}.         cap gen `var'_pval_bc = (`var'_rmspe_bc_rank - 1) / (J - 1)
{txt}  6{com}.         
. {c )-}
{txt}
{com}. 
. save "$path/results/embargo-th-results.dta", replace
{txt}{p 0 4 2}
file {bf}
/Users/jamiepavlik/Dropbox/cuba-replication//results/embargo-th-results.dta{rm}
saved
{p_end}

{com}. 
. 
{txt}end of do-file

{com}. 
. //------------------------------------------------------------------------------
. // Figure B2 - Embargo results using TRADHIST data, , Panels A-D
. //------------------------------------------------------------------------------
