{browse "https://justinwiltshire.com/s/allsynth_Wiltshire.pdf":Wiltshire, Justin C., 2022.  allsynth: (Stacked) Synthetic Control Bias-Correction Utilities for Stata. Working paper.}

{hline}

{com}. 
.         mat V = e(V_matrix)
{txt}
{com}.         esttab mat(V) using "$path/results/v-matrix/adj_mad23-pr.dta", replace mlab(none)
{res}{txt}(output written to {browse  `"/Users/jamiepavlik/Dropbox/cuba-replication//results/v-matrix/adj_mad23-pr.dta"'})

{com}.                          
. 
. // Adjusted Maddison Minus Transfers
. //------------------------------------------------------------------------------
. 
. allsynth adj_transf23 adj_transf23(1957) adj_transf23(1956) ///
>         adj_transf23(1953) adj_transf23(1950) adj_transf23(1947) ///
>         adj_transf23(1940)  adj_transf23(1935) $predictors, ///
>         trunit(8) trperiod($treat_y) ///
>         unitnames(country_moxlad) ///
>         resultsperiod($x_axis) ///
>         pvalues(rmspe) bcorrect(merge ridge) ///
>         keep($path/results/adj_transf23-pr-results.dta, replace) 
