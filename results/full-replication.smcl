{res}{txt}{p 0 4 2}
file {bf}
/var/folders/tp/nk2fqgtj2b13chwzpf57v5wm0000gn/T//S_25990.000005{rm}
saved
as .dta format
{p_end}

{com}. 
. 
. //------------------------------------------------------------------------------
. // Calculate Standardized p-values 
. //------------------------------------------------------------------------------
. 
. foreach var in gdppc23 adj_mad23 adj_transf23 {c -(}
{txt}  2{com}.         
.         // Compute p-values following Galliani and Quirstoff
.         qui distinct country
{txt}  3{com}.         scalar J = r(ndistinct)
{txt}  4{com}.         gen `var'_pval = (`var'_rmspe_rank - 1) / (J - 1)
{txt}  5{com}.         gen `var'_pval_bc = (`var'_rmspe_bc_rank - 1) / (J - 1)
{txt}  6{com}.         
.         
. {c )-}
{txt}(527 missing values generated)
(527 missing values generated)
(527 missing values generated)
(527 missing values generated)
(527 missing values generated)
(527 missing values generated)

{com}. 
. 
. save "$path/results/gdp-pr-results.dta", replace
{txt}{p 0 4 2}
file {bf}
/Users/jamiepavlik/Dropbox/cuba-replication//results/gdp-pr-results.dta{rm}
saved
{p_end}

{com}. 
. 
{txt}end of do-file

{com}. 
. //------------------------------------------------------------------------------
. // Figure B3 - GDP results including Puerto Rico, Panels A-F
. //------------------------------------------------------------------------------
. 
. di "Replicating Figure B3-A"
{res}Replicating Figure B3-A
{txt}
{com}. do "$path/code/FigureB1-A.do"
{txt}
{com}. *|==============================================================================
. *| TITLE
. *| The Forsaken Road
. *|
. *| AUTHORS
. *| JoĂŁo Pedro Bastos
. *| Texas Tech University | Joao-Pedro.Bastos@ttu.edu
. *|
. *| Jamie Bologna Pavlik
. *| Texas Tech University | Jamie.Bologna@ttu.edu
. *| 
. *| Vincent Geloso
. *| George Mason University |
. *|
. *| Function: Replicates Figure B1-A
. *|==============================================================================
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. // Load Data
. use "$path/results/gdp13-results.dta", clear
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)

{com}. 
. //------------------------------------------------------------------------------
. // Plot
. //------------------------------------------------------------------------------
. 
. *| Graph Setup
. global ytitle   = "GDP per capita"
{txt}
{com}. global xtitle   = "Year"
{txt}
{com}. global treat_graph  = $treat_y -1
{txt}
{com}. 
. *| Unadjusted GDP per Capita
.                    
. global ytitle   = "Unadjusted GDP per capita"
{txt}
{com}. twoway line gdppc13        year if country=="Cuba", lpattern(solid)                                              ///
>         || line gdppc13_synth    year if country=="Cuba", lpattern(dash) ///  
>            xline($treat_graph)           ///
>            xlabel(1929(5)1990, labsize(small)) ///
>            ylabel(1000(1000)6000, labsize(small))                                                                                        ///
>            ytitle($ytitle, size(small)) xtitle($xtitle, size(small)) ///
>            ysize(5) xsize(6)                                                                                                     ///
>            legend(label(1 "Cuba") label(2 "Synthetic Cuba") ///
>            position(6) rows(1) size(small)) 
{res}{txt}
{com}.            
. graph save "$path/figures/FigureB1-A.gph", replace
{res}{txt}file {bf:/Users/jamiepavlik/Dropbox/cuba-replication//figures/FigureB1-A.gph} saved

{com}. graph export "$path/figures/FigureB1-A.png", replace
{txt}{p 0 4 2}
