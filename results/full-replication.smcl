{cmd:________________________________}

{cmd:allsynth is a user-written command made freely-available to the research community. Please cite the paper:}

{browse "https://justinwiltshire.com/s/allsynth_Wiltshire.pdf":Wiltshire, Justin C., 2022.  allsynth: (Stacked) Synthetic Control Bias-Correction Utilities for Stata. Working paper.}

{hline}

{com}.         
.         mat V = e(V_matrix)
{txt}
{com}.         esttab mat(V) using "$path/results/v-matrix/trade-th.dta", ///
>         replace mlab(none)
{res}{txt}(output written to {browse  `"/Users/jamiepavlik/Dropbox/cuba-replication//results/v-matrix/trade-th.dta"'})

{com}. 
. 
. //------------------------------------------------------------------------------
. // Clean and merge data
. //------------------------------------------------------------------------------
. 
. use "$path/results/embargo-th-results.dta", clear
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)

{com}. 
. keep countrycode country id year ///
>         gdppc23 adj_mad23 adj_transf23 ///
>         schooling urban /// 
>         us_trade_th trade_th
{txt}
{com}. 
. foreach var in us_trade_th trade_th {c -(}
{txt}  2{com}.         
.         tempfile temp_results // Declare a temporary file name
{txt}  3{com}.         
.         preserve // Preserve the main data in memory
{txt}  4{com}.         
.         // Load the allsynth output file
.         use "$path/results/`var'-results.dta", clear
{txt}  5{com}.         
.         cap drop unique_W
{txt}  6{com}.         drop _Y_treated // This would be repeatedÂ 
{txt}  7{com}.         
.         cap rename _time year // Rename to match main file's merge key
{txt}  8{com}.         cap rename _Y_treated_bc `var'_bc
{txt}  9{com}.         cap rename _Y_synthetic_bc `var'_synth_bc
{txt} 10{com}.         cap rename _Y_synthetic `var'_synth
{txt} 11{com}.         cap rename _W_Weight `var'_Weight
{txt} 12{com}.         cap rename _Co_Number `var'_donor_lab
{txt} 13{com}.         cap rename N N_`var'
{txt} 14{com}.         
.         // Create a sample tag 
.         gen sample_`var' = 1
{txt} 15{com}.         
.         foreach v in gap gap_bc rmspe rmspe_rank rmspe_bc rmspe_bc_rank p p_bc {c -(}
{txt} 16{com}.                 cap rename `v' `var'_`v'
{txt} 17{com}.         {c )-}
{txt} 18{com}.    
.     save `temp_results', replace // Save the edited file temporarily
{txt} 19{com}.         
.         restore // Restore the main data
{txt} 20{com}.         
.         // Merge the edited tempfile into the main data
.         qui merge 1:1 id year using `temp_results'
{txt} 21{com}.         drop _merge // Clean up after merge
{txt} 22{com}. {c )-}
{txt}{p 0 4 2}
