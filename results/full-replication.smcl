. *| Function: Generates synthetic control estimates for GDP, 2013 MPD Data
. *| - Output gdp13-results.dta will be used for several figures later
. *|
. *|==============================================================================
. 
. //------------------------------------------------------------------------------
. // Setup
. //------------------------------------------------------------------------------
. ereturn clear
{txt}
{com}. clear results
{txt}
{com}. clear mata 
{txt}
{com}. clear matrix 
{txt}
{com}. clear ado
{txt}
{com}. 
. // Install packages if necessary (they have been installed in the main file)
. * ssc install synth
. * ssc install synth_runner
. * ssc install allsynth
. * ssc install distinct // required by allsynth
. * ssc install elasticregress // required by allsynth
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. // Load Data
. use "$path/data/master.dta", clear
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)

{com}. 
. tsset id year
{res}
{col 1}{txt:Panel variable: }{res:id}{txt: (unbalanced)}
{p 1 16 2}{txt:Time variable: }{res:year}{txt:, }{res:{bind:1}}{txt: to }{res:{bind:2018}}{txt:, but with gaps}{p_end}
{txt}{col 10}Delta: {res}1 unit
{txt}
{com}. 
. // Create sample
. keep if latam==1
{txt}(2,116 observations deleted)

{com}. drop if year<1929 | year>1989 // In 2013 version, Cuban data starts in 1929
{txt}(2,007 observations deleted)

{com}. drop if country_moxlad==""
{txt}(162 observations deleted)

{com}. drop if country=="Bolivia" // In the 2013 version, data starts in 1945
{txt}(61 observations deleted)

{com}. 
. replace adj_mad13 = gdppc13 if country != "Cuba"
{txt}(854 real changes made)

{com}. replace adj_transf13 = gdppc13 if country != "Cuba"
{txt}(854 real changes made)

