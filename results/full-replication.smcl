{com}. 
. // Installed requires packages if not installed 
. * ssc install synth
. * ssc install allsynth
. * ssc install distinct // required by allsynth
. * ssc install elasticregress // required by allsynth
. * ssc install sdid
. * ssc install sdid_event 
. * ssc install rcm 
. * ssc install coefplot 
. * ssc install eventdd  
. 
. // Note: In case of "conformbility error", refer to README file in the package.
. 
. //------------------------------------------------------------------------------
. // Estimate the GDP results (used later for multiple figures)
. //------------------------------------------------------------------------------
. 
. di "Estimating Main GDP Results"
{res}Estimating Main GDP Results
{txt}
{com}. do "$path/code/gdp-results.do"
{txt}
{com}. *|==============================================================================
. *| TITLE
. *| The Forsaken Road
. *|
. *| AUTHORS
. *| JoĂŁo Pedro Bastos
. *| Texas Tech University | Joao-Pedro.Bastos@ttu.edu
. *|
. *| Jamie Bologna Pavlik
. *| Texas Tech University | Jamie.Bologna@ttu.edu
. *| 
. *| Vincent Geloso
. *| George Mason University |
. *|
. *| Function: Generates synthetic control estimates for GDP
. *| - Output gdp-results.dta will be used for several figures later
. *| â€“
. *|==============================================================================
. 
. //------------------------------------------------------------------------------
. // Setup
. //------------------------------------------------------------------------------
. ereturn clear
{txt}
{com}. clear results
{txt}
{com}. clear mata 
{txt}
{com}. clear matrix 
{txt}
{com}. clear ado
{txt}
{com}. 
. // Install packages if necessary (they have been installed in the main file)
. * ssc install synth
. * ssc install synth_runner
. * ssc install allsynth
. * ssc install distinct // required by allsynth
. * ssc install elasticregress // required by allsynth
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. // Load Data
. use "$path/data/master.dta", clear
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)

{com}. 
. tsset id year
{res}
{col 1}{txt:Panel variable: }{res:id}{txt: (unbalanced)}
{p 1 16 2}{txt:Time variable: }{res:year}{txt:, }{res:{bind:1}}{txt: to }{res:{bind:2018}}{txt:, but with gaps}{p_end}
{txt}{col 10}Delta: {res}1 unit
{txt}
{com}. 
. // Create sample
. keep if latam==1
{txt}(2,116 observations deleted)

{com}. drop if year<1928 | year>1989
{txt}(1,989 observations deleted)

{com}. drop if country_moxlad==""
{txt}(164 observations deleted)

{com}. 
. // Define globals 
. global treat_y = 1959
{txt}
{com}. global predictors = "urban schooling"
{txt}
{com}. global x_axis = "1928(1)1989"
{txt}
{com}. 
. //------------------------------------------------------------------------------
. // Main Results: GDP
. //------------------------------------------------------------------------------
. 
. 
. // Unadjusted GDP
. //------------------------------------------------------------------------------
. 
. allsynth gdppc23 gdppc23(1957) gdppc23(1956) gdppc23(1953) ///
>         gdppc23(1950) gdppc23(1947)  gdppc23(1940)  gdppc23(1935) ///
>         $predictors, trunit(8) trperiod($treat_y) ///
>         unitnames(country_moxlad) resultsperiod($x_axis) ///
>         pvalues(rmspe) bcorrect(merge ridge)  ///
>         keep($path/results/gdppc23-results.dta, replace)
{txt}{hline}
