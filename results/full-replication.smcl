{cmd:________________________________}

{cmd:allsynth is a user-written command made freely-available to the research community. Please cite the paper:}

{browse "https://justinwiltshire.com/s/allsynth_Wiltshire.pdf":Wiltshire, Justin C., 2022.  allsynth: (Stacked) Synthetic Control Bias-Correction Utilities for Stata. Working paper.}

{hline}

{com}. 
.         mat V = e(V_matrix)
{txt}
{com}.         esttab mat(V) using "$path/results/v-matrix/adj_transf13.dta", ///
>                 replace mlab(none)
{res}{txt}(output written to {browse  `"/Users/jamiepavlik/Dropbox/cuba-replication//results/v-matrix/adj_transf13.dta"'})

{com}. 
. //------------------------------------------------------------------------------
. // Clean and merge data
. //------------------------------------------------------------------------------
. 
. keep countrycode country id latam former_ussr communist year ///
>         gdppc13 adj_mad13 adj_transf13 schooling urban
{txt}
{com}. 
. foreach var in gdppc13 adj_mad13 adj_transf13 {c -(}
{txt}  2{com}.         
.         tempfile temp_results // Declare a temporary file name
{txt}  3{com}.         
.         preserve // Preserve the main data in memory
{txt}  4{com}.         
.         // Load the allsynth output file
.         use "$path/results/`var'-results.dta", clear
{txt}  5{com}.         
.         drop unique_W N
{txt}  6{com}.         drop _Y_treated // This would be repeatedÂ 
{txt}  7{com}.         
.         rename _time year // Rename to match main file's merge key
{txt}  8{com}.         rename _Y_treated_bc `var'_bc
{txt}  9{com}.         rename _Y_synthetic_bc `var'_synth_bc
{txt} 10{com}.         rename _Y_synthetic `var'_synth
{txt} 11{com}.         rename _W_Weight `var'_Weight
{txt} 12{com}.         rename _Co_Number `var'_donor_lab
{txt} 13{com}.         
.         foreach v in gap gap_bc rmspe rmspe_rank rmspe_bc rmspe_bc_rank p p_bc {c -(}
{txt} 14{com}.                 rename `v' `var'_`v'
{txt} 15{com}.         {c )-}
{txt} 16{com}.    
.     save `temp_results' // Save the edited file temporarily
{txt} 17{com}.         
.         restore // Restore the main data
{txt} 18{com}.         
.         // Merge the edited tempfile into the main data
.         qui merge 1:1 id year using `temp_results'
{txt} 19{com}.         drop _merge // Clean up after merge
{txt} 20{com}. {c )-}
{res}{txt}{p 0 4 2}
file {bf}
/var/folders/tp/nk2fqgtj2b13chwzpf57v5wm0000gn/T//S_25990.000001{rm}
saved
as .dta format
{p_end}
{res}{txt}{p 0 4 2}
file {bf}
/var/folders/tp/nk2fqgtj2b13chwzpf57v5wm0000gn/T//S_25990.000003{rm}
saved
as .dta format
{p_end}
{res}{txt}{p 0 4 2}
file {bf}
/var/folders/tp/nk2fqgtj2b13chwzpf57v5wm0000gn/T//S_25990.000005{rm}
saved
as .dta format
{p_end}

{com}. 
. 
. //------------------------------------------------------------------------------
. // Calculate Standardized p-values 
. //------------------------------------------------------------------------------
. 
. foreach var in gdppc13 adj_mad13 adj_transf13 {c -(}
{txt}  2{com}.         
.         // Compute p-values following Galliani and Quirstoff
.         qui distinct country
{txt}  3{com}.         scalar J = r(ndistinct)
{txt}  4{com}.         gen `var'_pval = (`var'_rmspe_rank - 1) / (J - 1)
{txt}  5{com}.         gen `var'_pval_bc = (`var'_rmspe_bc_rank - 1) / (J - 1)
{txt}  6{com}.         
.         
. {c )-}
{txt}(450 missing values generated)
(450 missing values generated)
(450 missing values generated)
(450 missing values generated)
(450 missing values generated)
(450 missing values generated)

{com}. 
. save "$path/results/gdp13-results.dta", replace
{txt}{p 0 4 2}
file {bf}
/Users/jamiepavlik/Dropbox/cuba-replication//results/gdp13-results.dta{rm}
saved
{p_end}

{com}. 
. 
{txt}end of do-file

{com}. 
. //------------------------------------------------------------------------------
. // Figure B1 - GDP results using MPD 2013, , Panels A-F
. //------------------------------------------------------------------------------
. 
. di "Replicating Figure B1-A"
{res}Replicating Figure B1-A
{txt}
{com}. do "$path/code/FigureB1-A.do"
{txt}
{com}. *|==============================================================================
. *| TITLE
. *| The Forsaken Road
. *|
. *| AUTHORS
. *| JoĂŁo Pedro Bastos
. *| Texas Tech University | Joao-Pedro.Bastos@ttu.edu
. *|
. *| Jamie Bologna Pavlik
. *| Texas Tech University | Jamie.Bologna@ttu.edu
. *| 
. *| Vincent Geloso
. *| George Mason University |
. *|
. *| Function: Replicates Figure B1-A
. *|==============================================================================
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. // Load Data
. use "$path/results/gdp13-results.dta", clear
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)

{com}. 
. //------------------------------------------------------------------------------
. // Plot
. //------------------------------------------------------------------------------
. 
. *| Graph Setup
. global ytitle   = "GDP per capita"
{txt}
{com}. global xtitle   = "Year"
{txt}
{com}. global treat_graph  = $treat_y -1
{txt}
{com}. 
. *| Unadjusted GDP per Capita
.                    
