{cmd:________________________________}

{cmd:allsynth is a user-written command made freely-available to the research community. Please cite the paper:}

{browse "https://justinwiltshire.com/s/allsynth_Wiltshire.pdf":Wiltshire, Justin C., 2022.  allsynth: (Stacked) Synthetic Control Bias-Correction Utilities for Stata. Working paper.}

{hline}
{res}{txt}(output written to {browse  `"/Users/jamiepavlik/Dropbox/cuba-replication//results/v-matrix/trade-out-21.dta"'})

{com}. 
.         
. 
. 
. //------------------------------------------------------------------------------
. // Clean and merge data
. //------------------------------------------------------------------------------
. 
. foreach var in trade us_imports us_trade {c -(}
{txt}  2{com}.     
.         // Load placeholder data
.     use "$path/results/embargo-results.dta", clear
{txt}  3{com}.     keep id year `var'_synth `var'_pval
{txt}  4{com}.     
.         // Keep only Cuba and relevant years
.         keep if id==8
{txt}  5{com}.         keep if `var'_synth!=.
{txt}  6{com}.         
.                 
.         // Declare temp file to store cleaned data
.     tempfile to_merge     
{txt}  7{com}. 
.     foreach j in 1 3 4 5 6 7 9 10 11 13 15 16 17 20 21 {c -(}
{txt}  8{com}.                 
.                 // Ignore units 3 and 9 for total trade
.                 if "`var'"=="trade" & (`j'==3 | `j'==9) {c -(}
{txt}  9{com}.                         continue
{txt} 10{com}.                 {c )-}
{txt} 11{com}.                 
.                 else {c -(}
{txt} 12{com}.                         
.                         preserve 
{txt} 13{com}.         
.                         // Load Data
.                         use "$path/results/jackknife-embargo/`var'-out-`j'.dta", clear
{txt} 14{com}.                         keep if id==8
{txt} 15{com}.                         
.                         cap drop unique_W
{txt} 16{com}.                         rename _time year
{txt} 17{com}.                         
.                         // Keep the outcome variable for Cuba just for the first iteration
.                         if `j' == 1{c -(}
{txt} 18{com}.                                 rename _Y_treated `var'
{txt} 19{com}.                         {c )-}
{txt} 20{com}.                         
.                         else {c -(}
{txt} 21{com}.                                 drop _Y_treated
{txt} 22{com}.                         {c )-}
{txt} 23{com}.                                 
.                         // Compute p-values following Galliani and Quirstoff
.                         qui sum N 
{txt} 24{com}.                         scalar J = r(mean)
{txt} 25{com}.                         cap gen `var'_pval_out`j' = (rmspe_rank - 1) / (J - 1)
{txt} 26{com}.                         
.                         drop p 
{txt} 27{com}.                         // Rename variables
.                         rename _Y_synthetic `var'_synth_out`j'
{txt} 28{com}.                         
.                         foreach v in gap rmspe N _Co_Number _W_Weight rmspe_rank {c -(}
{txt} 29{com}.                                 cap rename `v' `var'_`v'_out`j'
{txt} 30{com}.                         {c )-}
{txt} 31{com}.                         
.                         // Save the cleaned data
.                         save `to_merge', replace
{txt} 32{com}.                         
.                         restore
{txt} 33{com}.                         
.                         // Merge to main dataset
.                         qui merge 1:1 id year using `to_merge'
{txt} 34{com}.                         drop _merge
{txt} 35{com}.                 {c )-}
{txt} 36{com}.     {c )-} 
{txt} 37{com}.      
.     save "$path/results/jackknife-embargo/`var'-jackknife-results.dta", replace
{txt} 38{com}.         
. {c )-}
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)
