. //------------------------------------------------------------------------------
. // Estimate the Jackknifed Embargo results (used later for multiple figures)
. //------------------------------------------------------------------------------
. 
. di "Estimating Jackknifed Embargo Results"
{res}Estimating Jackknifed Embargo Results
{txt}
{com}. do "$path/code/jackknife-embargo.do"
{txt}
{com}. *|==============================================================================
. *| TITLE
. *| The Forsaken Road
. *|
. *| AUTHORS
. *| JoĂŁo Pedro Bastos
. *| Texas Tech University | Joao-Pedro.Bastos@ttu.edu
. *|
. *| Jamie Bologna Pavlik
. *| Texas Tech University | Jamie.Bologna@ttu.edu
. *| 
. *| Vincent Geloso
. *| George Mason University |
. *|
. *| Function: Generates jackknifed SCM estimates for the effect of the embargo
. *| - Output jackknife-embargo.dta will be used for plotting later
. *|==============================================================================
. 
. //------------------------------------------------------------------------------
. // Setup
. //------------------------------------------------------------------------------
. ereturn clear
{txt}
{com}. clear results
{txt}
{com}. clear mata 
{txt}
{com}. clear matrix 
{txt}
{com}. 
. // Install packages if necessary (they have been installed in the main file)
. * ssc install synth
. * ssc install synth_runner
. * ssc install allsynth
. * ssc install distinct // required by allsynth
. * ssc install elasticregress // required by allsynth
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. //------------------------------------------------------------------------------
. // Total Trade with the US
. //------------------------------------------------------------------------------
. 
. // Define globals 
. global treat_y = 1959
{txt}
{com}. global predictors        = "gdppc23 schooling urban"
{txt}
{com}. global x_axis            = "1938(1)1972"
{txt}
{com}. 
. foreach j in 1 3 4 5 6 7 9 10 11 13 15 16 17 20 21 {c -(}
{txt}  2{com}. 
.         // Load Data
.         use "$path/data/master.dta", clear
{txt}  3{com}. 
.         tsset id year
{txt}  4{com}. 
.         // Create sample
.         keep if latam==1
{txt}  5{com}.         drop if country_moxlad==""
{txt}  6{com}.         drop if year<1938 | year>1972
{txt}  7{com}. 
.         // Drop the country
.         drop if id==`j'
{txt}  8{com}. 
.         // Total Trade with the US
.         //--------------------------------------------------------------------------
. 
.         allsynth us_trade /// Outcome
>                 us_trade(1958) us_trade(1957) us_trade(1956) /// Lags
>                 us_trade(1953) us_trade(1950) us_trade(1947) ///
>                 us_trade(1944) us_trade(1941) us_trade(1938) ///
>                 $predictors, /// Predictors 
>                 trunit(8) trperiod($treat_y) ///
>                 unitnames(country_moxlad) resultsperiod($x_axis) ///
>                 pvalues(rmspe)  ///
>                 keep($path/results/jackknife-embargo/us_trade-out-`j'.dta, replace)
{txt}  9{com}. 
.                 mat V = e(V_matrix)
{txt} 10{com}.                 esttab mat(V) using "$path/results/v-matrix/us-trade-out-`j'.dta", ///
>                 replace mlab(none)
{txt} 11{com}.                         
.         // Cuba Exports to US / US Imports from Cuba
.         //--------------------------------------------------------------------------
.         
.         allsynth us_imports /// Outcome
>                 us_imports(1958) us_imports(1957) us_imports(1956) /// Lags
>                 us_imports(1953) us_imports(1950) us_imports(1947) ///
>                 us_imports(1944) us_imports(1941) us_imports(1938) ///
>                 $predictors, /// Predictors 
>                 trunit(8) trperiod($treat_y) ///
>                 unitnames(country_moxlad) resultsperiod($x_axis) ///
>                 pvalues(rmspe)  ///
>                 keep($path/results/jackknife-embargo/us_imports-out-`j'.dta, replace)
{txt} 12{com}. 
.                 mat V = e(V_matrix)
{txt} 13{com}.                 esttab mat(V) using "$path/results/v-matrix/us-imports-out-`j'.dta", ///
>                 replace mlab(none)
{txt} 14{com}.                 
. {c )-}
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)
{res}
