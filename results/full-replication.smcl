{com}. *|==============================================================================
. *| TITLE
. *| The Forsaken Road
. *|
. *| AUTHORS
. *| JoĂŁo Pedro Bastos
. *| Texas Tech University | Joao-Pedro.Bastos@ttu.edu
. *|
. *| Jamie Bologna Pavlik
. *| Texas Tech University | Jamie.Bologna@ttu.edu
. *| 
. *| Vincent Geloso
. *| George Mason University |
. *|
. *| Function: Generates synthetic control estimates for GDP
. *| - Output gdp-results.dta will be used for several figures later
. *| â€“
. *|==============================================================================
. 
. //------------------------------------------------------------------------------
. // Setup
. //------------------------------------------------------------------------------
. ereturn clear
{txt}
{com}. clear results
{txt}
{com}. clear mata 
{txt}
{com}. clear matrix 
{txt}
{com}. 
. // Install packages if necessary (they have been installed in the main file)
. * ssc install synth
. * ssc install synth_runner
. * ssc install allsynth
. * ssc install distinct // required by allsynth
. * ssc install elasticregress // required by allsynth
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. //------------------------------------------------------------------------------
. // Load and Clean Data
. //------------------------------------------------------------------------------
. 
. // Load Data
. use "$path/data/master.dta", clear
{txt}(Replication Data for Bastos, Geloso and Pavlik (2026): The Forsaken Road)

{com}. 
. keep if latam==1
{txt}(2,116 observations deleted)

{com}. 
. // Create sample
. drop if year<1922 | year>1989 
{txt}(1,881 observations deleted)

{com}. 
. drop if country=="" // No predictor data
{txt}(0 observations deleted)

{com}. drop if country=="Puerto Rico" | /// no trade data
>         country=="Barbados" | /// Data starts in 1950
>         country=="Guatemala" | /// gaps between 1942-1945 -- too much to interpolate
>         country=="Honduras" | /// gaps between 1939-1941
>         country=="Costa Rica" /// gaps between 1939 and 1945 
> 
{txt}(312 observations deleted)

{com}. sort id year
{txt}
{com}. tsset id year
{res}
{col 1}{txt:Panel variable: }{res:id}{txt: (strongly balanced)}
{p 1 16 2}{txt:Time variable: }{res:year}{txt:, }{res:{bind:1922}}{txt: to }{res:{bind:1989}}{p_end}
{txt}{col 10}Delta: {res}1 unit
{txt}
{com}. 
. save "$path/results/embargo-th-results.dta", replace
{txt}{p 0 4 2}
file {bf}
/Users/jamiepavlik/Dropbox/cuba-replication//results/embargo-th-results.dta{rm}
saved
{p_end}

{com}. 
. // Define globals 
. global treat_y = 1959
{txt}
{com}. global predictors        = "adj_mad23 schooling urban"
{txt}
{com}. global x_axis            = "1922(1)1989"
{txt}
{com}. 
. //------------------------------------------------------------------------------
. // Total Trade with the US
. //------------------------------------------------------------------------------
. 
. allsynth us_trade_th /// Outcome
>         us_trade_th(1958) us_trade_th(1956) /// Lags
>         us_trade_th(1953) us_trade_th(1951) us_trade_th(1947) ///
>         us_trade_th(1944) us_trade_th(1941) us_trade_th(1938) ///
>         $predictors, /// Predictors 
>         trunit(8) trperiod($treat_y) ///
>         unitnames(country) resultsperiod($x_axis) ///
>         pvalues(rmspe) ///
>         keep($path/results/us_trade_th-results.dta, replace)
{txt}{hline}
{res}Synthetic Control Method for Comparative Case Studies
{txt}{hline}

