. reshape long eff_ sig_, i(lead) j(country) string
{txt}(j = Bhutan CAF Ecuador08 Ecuador98 Egypt Eswatini Kenya Maldives Morocco Namibia Nepal75 Nepal90 TT Zambia73 Zambia91 Zimbabwe00 Zimbabwe13)

Data{col 36}Wide{col 43}->{col 48}Long
{hline 77}
Number of observations     {res}          11   {txt}->   {res}187         
{txt}Number of variables        {res}          35   {txt}->   {res}4           
{txt}j variable (17 values)                    ->   {res}country
{txt}xij variables:
  {res}eff_Bhutan eff_CAF ... eff_Zimbabwe13   {txt}->   {res}eff_
  sig_Bhutan sig_CAF ... sig_Zimbabwe13   {txt}->   {res}sig_
{txt}{hline 77}

{com}. rename eff_ effect
{res}{txt}
{com}. rename sig_ pval
{res}{txt}
{com}. 
. gen byte positive = effect > 0  if !missing(effect)
{txt}(4 missing values generated)

{com}. gen byte negative = effect < 0  if !missing(effect)
{txt}(4 missing values generated)

{com}. gen byte sig      = pval  <= 0.10 if !missing(pval)
{txt}(4 missing values generated)

{com}. gen byte pos_sig  = positive & sig
{txt}
{com}. gen byte neg_sig  = negative & sig
{txt}
{com}. 
. collapse (sum) positive negative pos_sig neg_sig (count) total=effect, by(lead)
{res}{txt}
{com}. 
{txt}end of do-file

