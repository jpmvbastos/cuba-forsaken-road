. //------------------------------------------------------------------------------
. // Estimate the Jackknifed GDP results (used later for multiple figures)
. //------------------------------------------------------------------------------
. 
. di "Estimating Jackknifed GDP Results"
{res}Estimating Jackknifed GDP Results
{txt}
{com}. do "$path/code/jackknife-gdp.do"
{txt}
{com}. *|==============================================================================
. *| TITLE
. *| The Forsaken Road
. *|
. *| AUTHORS
. *| JoĂŁo Pedro Bastos
. *| Texas Tech University | Joao-Pedro.Bastos@ttu.edu
. *|
. *| Jamie Bologna Pavlik
. *| Texas Tech University | Jamie.Bologna@ttu.edu
. *| 
. *| Vincent Geloso
. *| George Mason University |
. *|
. *| Function: Generates jackknifed SCM estimates for GDP
. *| - Output jackknife-gdp.dta will be used for plotting later
. *|==============================================================================
. 
. //------------------------------------------------------------------------------
. // Setup
. //------------------------------------------------------------------------------
. ereturn clear
{txt}
{com}. clear results
{txt}
{com}. clear mata 
{txt}
{com}. clear matrix 
{txt}
{com}. 
. // Install packages if necessary (they have been installed in the main file)
. * ssc install synth
. * ssc install synth_runner
. * ssc install allsynth
. * ssc install distinct // required by allsynth
. * ssc install elasticregress // required by allsynth
. 
. // Adjust path if running this file by itself
. * global path ""
. 
. //------------------------------------------------------------------------------
. // Jackknifed GDP Results
. //------------------------------------------------------------------------------
. 
. // Global Setup
. global treat_y       = "1959"
{txt}
{com}. global x_axis            = "1928(1)1989"
{txt}
{com}. global predictors        = "urban schooling"
{txt}
{com}. 
. foreach j in 1 3 4 5 6 7 9 10 11 13 15 16 17 20 21 {c -(}
{txt}  2{com}.         
.         // Load Data
.         qui use "$path/data/master.dta", clear
{txt}  3{com}.         
.         // Save the name of the country that is dropped 
.         qui levelsof country if id == `j', local(cname)
{txt}  4{com}.         qui gen dropped_out`j' = `" `cname' "'
{txt}  5{com}.         
.         // Create sample
.         quietly {c -(}
{txt}  6{com}.         drop if year<1928 | year>1989
{txt}  7{com}.         keep if latam==1
{txt}  8{com}.         drop if country_moxlad==""
{txt}  9{com}.         tsset id year
{txt} 10{com}.         
.         // Drop the country
.         drop if id==`j'
{txt} 11{com}.         
.         {c )-}
{txt} 12{com}. 
.         // Unadjusted GDP per capita
.         //--------------------------------------------------------------------------
. 
.         allsynth gdppc23 /// Outcome
>                 gdppc23(1957) gdppc23(1956) gdppc23(1953) ///
>                 gdppc23(1950) gdppc23(1947)  gdppc23(1940)  ///
>                 gdppc23(1935) ///
>                 $predictors, /// Predictors 
>                 trunit(8) trperiod($treat_y) ///
>                 unitnames(country) resultsperiod($x_axis) ///
>                 pvalues(rmspe)  ///
>                 keep($path/results/jackknife-gdp/gdppc23-out`j'.dta, replace)
{txt} 13{com}. 
.                 qui mat V = e(V_matrix)
{txt} 14{com}.                 qui esttab mat(V) using "$path/results/v-matrix/gdppc23-out`j'.dta", ///
>                 replace mlab(none)
{txt} 15{com}.                 
.         // Adjusted GDP per capita
.         //--------------------------------------------------------------------------
.                 
.         allsynth adj_mad23 /// Outcome
>                 adj_mad23(1957) adj_mad23(1956) adj_mad23(1953) ///
>                 adj_mad23(1950) adj_mad23(1947)  adj_mad23(1940)  ///
>                 adj_mad23(1935) ///
>                 $predictors, /// Predictors 
>                 trunit(8) trperiod($treat_y) ///
>                 unitnames(country) resultsperiod($x_axis) ///
>                 pvalues(rmspe)  ///
>                 keep($path/results/jackknife-gdp/adj_mad23-out`j'.dta, replace)
{txt} 16{com}. 
.                 qui mat V = e(V_matrix)
{txt} 17{com}.                 qui esttab mat(V) using "$path/results/v-matrix/adj_mad23-out`j'.dta", ///
>                 replace mlab(none)
{txt} 18{com}.                 
.         // Adjusted GDP per capita minus transfers
.         //--------------------------------------------------------------------------
.         
.         allsynth adj_transf23 /// Outcome
>                 adj_transf23(1957) adj_transf23(1956) adj_transf23(1953) ///
>                 adj_transf23(1950) adj_transf23(1947)  adj_transf23(1940) ///
>                 adj_transf23(1935) ///
>                 $predictors, /// Predictors 
>                 trunit(8) trperiod($treat_y) ///
>                 unitnames(country) resultsperiod($x_axis) ///
>                 pvalues(rmspe) ///
>                 keep($path/results/jackknife-gdp/adj_transf23-out`j'.dta, replace)
{txt} 19{com}. 
.                 qui mat V = e(V_matrix)
{txt} 20{com}.                 qui esttab mat(V) using "$path/results/v-matrix/adj_transf23-out`j'.dta", ///
>                 replace mlab(none)
{txt} 21{com}.         
.         {c )-}
{txt}{hline}
{res}Synthetic Control Method for Comparative Case Studies
{txt}{hline}

{res}First Step: Data Setup
{txt}{hline}
