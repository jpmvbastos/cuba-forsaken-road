{com}. /*
> ******************************************************************************************
> **#Step 4: Synth Runner, Just Lagged Outcomes
> */
> 
> foreach outcome of local outcomelist
> {c -(};
{txt}  2{com}. synth_runner    `outcome'
>                                 `outcome'(1) `outcome'(2) `outcome'(3) `outcome'(4) `outcome'(5)
>                                 `outcome'(6) `outcome'(7) `outcome'(8) `outcome'(9) `outcome'(10)
>                                 ,
>                 trunit(`id') trperiod(11) unitnames(country)
>                 keep("`path'Synth_Results/Placebo_Effects/Treatment_Group_1/`outcome'_`results'.dta") replace;
{txt}  3{com}.                                 matrix B = e(b) ;
{txt}  4{com}.                 matrix P = e(pvals_std) ;
{txt}  5{com}.                 local npost = colsof(P) ;
{txt}  6{com}.                 tempname M ;
{txt}  7{com}.                 postfile `M' int lead double eff_`cname' double sig_`cname'
>         using "`path'/Synth_Results/Summaries/byyear_`cname'_`outcome'_centered.dta", replace ;
{txt}  8{com}.                 forvalues L = 1/`npost' {c -(};
{txt}  9{com}.         post `M' (`L') (B[1,`L']) (P[1,`L']) ;
{txt} 10{com}.                 {c )-};
{txt} 11{com}.                 postclose `M' ;
{txt} 12{com}.                         pval_graphs;
{txt} 13{com}.                 graph close "pvals";
{txt} 14{com}.                 graph save "`path'Synth_Results/Graphs_for_Paper/Treatment_Group_1/`outcome'_`results'pval.gph", replace;
{txt} 15{com}. {c )-};
