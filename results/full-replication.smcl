{com}. replace event_time = -5  if f5.event_year != .
{txt}(100 real changes made)

{com}. replace event_time = -6  if f6.event_year != .
{txt}(100 real changes made)

{com}. replace event_time = -7  if f7.event_year != .
{txt}(100 real changes made)

{com}. replace event_time = -8  if f8.event_year != .
{txt}(100 real changes made)

{com}. replace event_time = -9  if f9.event_year != .
{txt}(100 real changes made)

{com}. replace event_time = -10 if f10.event_year != .
{txt}(100 real changes made)

{com}. 
. *gen synth_year so we have uniform coding across paper -- YEAR 11 is EVENT YEAR
. gen synth_year = event_time + 11
{txt}
{com}. 
. 
. *Fix country names to allow two events per country
. replace country = "Angola2"  if country == "Angola"  & year > 1985
{txt}(21 real changes made)

{com}. replace country = "Comoros2" if country == "Comoros" & year > 1988
{txt}(21 real changes made)

{com}. replace country = "Congo2" if country == "Congo" & year > 1989
{txt}(21 real changes made)

{com}. replace country = "Gambia2" if country == "Gambia" & year > 1980
{txt}(21 real changes made)

{com}. replace country = "Malawi2" if country == "Malawi" & year > 1976
{txt}(21 real changes made)

{com}. replace country = "Somalia2" if country == "Somalia" & year > 1989
{txt}(21 real changes made)

{com}. 
. replace country = "Albania2" if country == "Albania" & year > 1986
{txt}(21 real changes made)

{com}. replace country = "Myanmar2" if country == "Myanmar" & year > 1984
{txt}(21 real changes made)

{com}. replace country = "Romania2" if country == "Romania" & year > 1975
{txt}(21 real changes made)

{com}. 
. replace country = "Libya2" if country == "Libya" & year > 1980
{txt}(21 real changes made)

{com}. replace country = "Qatar2" if country == "Qatar" & year > 1980
{txt}(21 real changes made)

{com}. replace country = "Syria2" if country == "Syria" & year > 1983
{txt}(21 real changes made)

{com}. replace country = "Yemen"  if country == "Yemen Arab Republic"
{txt}(21 real changes made)

{com}. 
. replace country = "Bolivia2"  if country == "Bolivia"  & year > 1977
{txt}(21 real changes made)

{com}. replace country = "Brazil2"   if country == "Brazil"   & year > 1977
{txt}(21 real changes made)

{com}. replace country = "Paraguay2" if country == "Paraguay" & year > 1977
{txt}(21 real changes made)

{com}. 
. drop c
{txt}
{com}. encode country, gen(c)
{txt}
{com}. 
. *Invert outcomes (higher value = more corruption control, consistent with other measures)
. replace v2x_pubcorr   = 1 - v2x_pubcorr
{txt}(2,100 real changes made)

{com}. replace v2x_corr      = 1 - v2x_corr
{txt}(2,100 real changes made)

{com}. replace v2xnp_regcorr = 1 - v2xnp_regcorr
{txt}(2,089 real changes made)

{com}. 
